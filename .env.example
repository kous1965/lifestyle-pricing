# Yahoo!ショッピング 注文API / 商品API の認証情報テンプレート
# 使うときは `cp .env.example .env` して実値を入れる。.env は .gitignore 済み。
#
# ストアクリエイターPro の アプリケーションID / シークレット(OAuth)
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
# OAuth で取得したトークン(refresh_token は失効しやすいので要再認証フロー ← 仕様書5章)
YAHOO_ACCESS_TOKEN=
YAHOO_REFRESH_TOKEN=
# 対象ストアアカウント
YAHOO_SELLER_ID=

# 実行モード: report_only / approval / auto
# ★安全のため既定は report_only。価格書き込みは approval/auto かつ明示フラグが無い限り行わない。
PRICING_EXECUTION_MODE=report_only
